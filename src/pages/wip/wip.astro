---
// src/pages/wip/wip.astro
import Layout from '../../layouts/Layout.astro'; 
---

<Layout>
    <div class="wip-content">
        <div class="game-wrapper">
            <div id="canvas-container"></div>
        </div>
        <div class="projects-list">
            <h2>Other WIP Projects</h2>
            <p>Scroll down to see more...</p>
        </div>
    </div>
    
    <script>
        async function loadScript(src) {
            return new Promise((resolve, reject) => {
                const s = document.createElement('script');
                s.src = src;
                s.async = false;
                s.onload = () => resolve();
                s.onerror = (e) => reject(e);
                document.head.appendChild(s);
            });
        }

        async function ensureP5AndStart() {
            if (typeof window.p5 === 'undefined') {
                try {
                    await loadScript('https://cdnjs.cloudflare.com/ajax/libs/p5.js/1.9.0/p5.min.js');
                    await loadScript('https://cdnjs.cloudflare.com/ajax/libs/p5.js/1.9.0/addons/p5.sound.min.js');
                } catch (e) {
                    console.error('Failed to load p5 libs:', e);
                    return;
                }
            }

            try {
                const mod = await import('../../scripts/wip/startSketch.js');
                if (mod && typeof mod.startSketch === 'function') {
                    mod.startSketch('canvas-container');
                }
            } catch (e) {
                console.error('Failed to import startSketch:', e);
            }
        }

        ensureP5AndStart();
        document.addEventListener('astro:page-load', ensureP5AndStart);
    </script>
</Layout>

<style>
    .wip-content {
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 100%;
        padding: 60px 0;
        gap: 40px;
    }
    .game-wrapper {
        width: 80vw;
        aspect-ratio: 16 / 9;
        border: 4px solid black;
        background-color: #ffffff;
        position: relative;
    }
    #canvas-container {
        width: 100%;
        height: 100%;
    }
    .projects-list {
        width: 80vw;
    }
</style>