---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="WIP Garden" isWip={true}>
    <div class="main-container">
        <div class="accordion-item active">
            <button class="accordion-header">
                <span class="title-wrapper"><span class="arrow">＞</span>wip encounter machine (ver1.0)</span>
            </button>
            <div class="accordion-content">
                <div class="inner-content">
                    <div class="game-wrapper">
                        <div id="canvas-container"></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="accordion-item">
            <button class="accordion-header">
                <span class="title-wrapper"><span class="arrow">＞</span>wip lists</span>
            </button>
            <div class="accordion-content">
                <div class="inner-content projects-list">
                    <h2>Other WIP Projects</h2>
                    <p>Scroll down to see more...</p>
                </div>
            </div>
        </div>
    </div>

    <script>
        /**
         * @param {string} src
         * @returns {Promise<void>}
         */
        async function loadScript(src) {
            return new Promise((resolve, reject) => {
                const s = document.createElement('script');
                s.src = src;
                s.async = false;
                s.onload = () => resolve(undefined);
                s.onerror = (e) => reject(e);
                document.head.appendChild(s);
            });
        }

        async function ensureP5AndStart() {
            // @ts-ignore
            if (typeof window.p5 === 'undefined') {
                try {
                    await loadScript('https://cdnjs.cloudflare.com/ajax/libs/p5.js/1.9.0/p5.min.js');
                    await loadScript('https://cdnjs.cloudflare.com/ajax/libs/p5.js/1.9.0/addons/p5.sound.min.js');
                } catch (e) {
                    console.error('Failed to load p5 libs:', e);
                    return;
                }
            }

            try {
                const mod = await import('../../scripts/wip/startSketch.js');
                if (mod && typeof mod.startSketch === 'function') {
                    mod.startSketch('canvas-container');
                    setTimeout(() => {
                        const activeItems = document.querySelectorAll('.accordion-item.active');
                        activeItems.forEach(item => {
                            const content = item.querySelector('.accordion-content');
                            if (content && content instanceof HTMLElement) {
                                content.style.maxHeight = content.scrollHeight + 'px';
                            }
                        });
                    }, 500);
                }
            } catch (e) {
                console.error('Failed to import startSketch:', e);
            }
        }

        function setupAccordion() {
            /** @type {NodeListOf<HTMLButtonElement>} */
            const headers = document.querySelectorAll('.accordion-header');
            const activeItems = document.querySelectorAll('.accordion-item.active');
            
            activeItems.forEach(item => {
                const content = item.querySelector('.accordion-content');
                if (content && content instanceof HTMLElement) {
                    content.style.maxHeight = content.scrollHeight + 'px';
                }
            });

            headers.forEach(header => {
                const newHeader = header.cloneNode(true);
                if (header.parentNode) header.parentNode.replaceChild(newHeader, header);
                
                newHeader.addEventListener('click', () => {
                    const item = newHeader.parentElement;
                    if (!item) return;

                    const content = item.querySelector('.accordion-content');
                    if (!content || !(content instanceof HTMLElement)) return;
         
                    const isOpen = item.classList.contains('active');

                    if (isOpen) {
                        item.classList.remove('active');
                        content.style.maxHeight = '0';
                    } else {
                        item.classList.add('active');
                        content.style.maxHeight = content.scrollHeight + 'px';
                    }
                });
            });
        }

        function initPage() {
            // Initialize coarse noise for WIP game area (pixel size 4)
            (async () => {
                try {
                    const mod = await import('../../scripts/noiseBackground.js');
                    if (mod && typeof mod.initNoiseBackground === 'function') mod.initNoiseBackground(4, 'green');
                } catch (e) {
                    console.error('initNoiseBackground failed:', e);
                }
            })();

            ensureP5AndStart();
            setupAccordion();
        }

        initPage();
        document.addEventListener('astro:page-load', initPage);
    </script>
</Layout>

<style>
    .main-container {
        width: 86vw;
        margin: 0 auto;
        padding: 0px 0 40px 0;
    }

    /* ヘッダーは Layout.astro に移譲されたため、ここでは定義しません */
    
    /* 既存のWIPコンテンツスタイル（維持） */
    .game-wrapper {
        width: 100%;
        aspect-ratio: 16 / 9;
        border: 4px solid #333;
        background-color: #ffffff;
        position: relative;
        margin-bottom: 20px;
    }
    
    #canvas-container {
        width: 100%;
        height: 100%;
    }
    
    .projects-list {
        width: 100%;
    }

    .accordion-item {
        border-bottom: 2px solid black;
        width: 100%;
    }
    .accordion-item:first-child {
        border-top: 2px solid black;
    }
    .accordion-header {
        width: 100%;
        background: none;
        border: none;
        font-family: inherit;
        font-size: 32px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 30px 0;
        cursor: pointer;
        text-align: left;
        color: #333;
        transition: color 0.2s ease;
    }
    .accordion-header:hover {
        color: #888;
    }
    
    .title-wrapper {
        display: flex;
        align-items: center;
    }

    .arrow {
        display: inline-block;
        margin-right: 12px;
        font-family: monospace;
        font-size: 0.9em;
        transition: transform 0.3s ease;
    }

    .accordion-item.active .arrow {
        transform: rotate(90deg);
    }

    .accordion-content {
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.3s ease-out;
    }
    .inner-content {
        padding: 10px 0 40px 0;
        font-size: 22px;
        line-height: 1.6;
    }
</style>