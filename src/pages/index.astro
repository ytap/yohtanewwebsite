---
import Layout from '../layouts/Layout.astro';

const featuredProjects = [
    {
        title: 'NoiseLoom',
        description: 'An intuitive yet unique multiplayer noise improvisation tool, for experts and non-experts.',
    image: '/yohtanewwebsite/assets/NoiseLoom1.png',
    link: '/yohtanewwebsite/projects/project-a'
    },
    {
        title: 'Contact Membrane',
        description: 'An interface to listen to mealworm beetles.',
    image: '/yohtanewwebsite/assets/mealworm1.png',
    link: '/yohtanewwebsite/projects/project-b'
    },
    {
        title: 'Project C',
        description: 'A real-time interactive system deploying creative coding techniques.',
    image: '/yohtanewwebsite/assets/project-c.jpg',
    link: '/yohtanewwebsite/projects/project-c'
    }
];
---

<Layout isHome={true}>
    <div class="main-container">
        <div class="hero-section">
            <div class="canvas-wrapper">
                <canvas id="title-canvas" class="procedural-title"></canvas>
                <canvas id="about-canvas" class="procedural-about"></canvas>
            </div>
            <canvas id="divider-canvas" class="procedural-divider"></canvas>
        </div>

        <section class="featured-section">
            <div class="marquee-container">
                <div class="marquee-track">
                    {/* 1周目: 左側の隙間を埋めるバッファ用 */}
                    {featuredProjects.map((project) => (
                        <a href={project.link} class="project-block" aria-hidden="true">
                            <div class="image-wrapper">
                                <img src={project.image} alt={project.title} class="project-img" />
                            </div>
                            <div class="project-text-content">
                                <h3 class="project-block-title">{project.title}</h3>
                                <p class="project-block-desc">{project.description}</p>
                            </div>
                        </a>
                    ))}

                    {/* 2周目: 初期状態で中央に表示されるメイン要素 */}
                    {featuredProjects.map((project) => (
                        <a href={project.link} class="project-block">
                            <div class="image-wrapper">
                                <img src={project.image} alt={project.title} class="project-img" />
                            </div>
                            <div class="project-text-content">
                                <h3 class="project-block-title">{project.title}</h3>
                                <p class="project-block-desc">{project.description}</p>
                            </div>
                        </a>
                    ))}

                    {/* 3周目: 右側に続くスライド用 */}
                    {featuredProjects.map((project) => (
                        <a href={project.link} class="project-block" aria-hidden="true">
                            <div class="image-wrapper">
                                <img src={project.image} alt={project.title} class="project-img" />
                            </div>
                            <div class="project-text-content">
                                <h3 class="project-block-title">{project.title}</h3>
                                <p class="project-block-desc">{project.description}</p>
                            </div>
                        </a>
                    ))}
                </div>
            </div>

            <div class="more-projects-link">
                For more projects, visit <a href="/yohtanewwebsite/archive">archive</a> or <a href="/yohtanewwebsite/wip">wip garden</a>. For details of past experiences and achievements, visit <a href="/yohtanewwebsite/about">about</a>.
            </div>
        </section>

            <div class="accordion-item">
                <button class="accordion-header">
                    <span class="title-wrapper"><span class="arrow">＞</span>News</span>
                </button>
                <div class="accordion-content">
                    <div class="inner-content">
                        <p>Coming soon...</p>
                    </div>
                </div>
            </div>

        </div>
    </Layout>

<script>
    import '../scripts/pages/main-canvas.js';

    function setupAccordion() {
        const headers = document.querySelectorAll('.accordion-header');
        headers.forEach(header => {
            // 古いイベントリスナーの重複を防ぐためにノードを複製
            const newHeader = header.cloneNode(true);
            if (header.parentNode) header.parentNode.replaceChild(newHeader, header);
            
            newHeader.addEventListener('click', () => {
                const item = newHeader.parentElement;
                if (!item) return;
                const content = item.querySelector('.accordion-content');
                if (!content || !(content instanceof HTMLElement)) return;

                const isOpen = item.classList.contains('active');
                if (isOpen) {
                    item.classList.remove('active');
                    content.style.maxHeight = '0'; // 閉じる
                } else {
                    item.classList.add('active');
                    content.style.maxHeight = content.scrollHeight + 'px'; // 中身の高さに合わせて開く
                }
            });
        });
    }

    function setupMarquee() {
        const track = document.querySelector('.marquee-track');
        if (!track || !(track instanceof HTMLElement)) return;
        const blocks = track.querySelectorAll('.project-block');
        if (blocks.length === 0) return;

        const images = Array.from(track.querySelectorAll('img'));
        const totalProjects = blocks.length / 3;

        const imageLoadPromises = images.map(img => {
            if (img.complete) return Promise.resolve();
            return new Promise(resolve => {
                img.onload = resolve;
                img.onerror = resolve;
            });
        });

        Promise.all(imageLoadPromises).then(() => {
            let currentIndex = totalProjects;
            let stepWidth = 0;
            let itemWidth = 0;

            function updateLayout() {
                if (!blocks[0]) return;
                itemWidth = blocks[0].getBoundingClientRect().width;
                const style = window.getComputedStyle(blocks[0]);
                stepWidth = itemWidth + (parseFloat(style.marginRight) || 0);
                updatePosition(true);
            }

            function updatePosition(instant = false) {
                if (instant) {
                    track.style.transition = 'none';
                } else {
                    track.style.transition = 'transform 1s cubic-bezier(0.22, 1, 0.36, 1)';
                }
                
                const centerOffset = (window.innerWidth / 2) - (stepWidth * currentIndex + itemWidth / 2);
                track.style.transform = `translateX(${centerOffset}px)`;
            }

            function nextSlide() {
                currentIndex++;
                updatePosition();
                if (currentIndex === totalProjects * 2) {
                    setTimeout(() => {
                        currentIndex = totalProjects;
                        updatePosition(true);
                    }, 1000); 
                }
            }

            window.addEventListener('resize', updateLayout);
            updateLayout();
            track.classList.add('is-loaded');

            let intervalId = 0;
            function startAutoPlay() {
                intervalId = window.setInterval(nextSlide, 5000);
            }
            function stopAutoPlay() {
                if (intervalId !== 0) window.clearInterval(intervalId);
            }
            
            startAutoPlay();
            track.addEventListener('mouseenter', stopAutoPlay);
            track.addEventListener('mouseleave', startAutoPlay);
        });
    }

    function initPage() {
        (async () => {
            try {
                const mod = await import('../scripts/noiseBackground.js');
                if (mod && typeof mod.initNoiseBackground === 'function') {
                    mod.initNoiseBackground(2);
                }
            } catch (e) {
                console.error('initNoiseBackground failed:', e);
            }
        })();

        (async () => {
            try {
                const mod = await import('../scripts/projectCardBorder.js');
                if (mod && typeof mod.initProjectCardBorders === 'function') {
                    mod.initProjectCardBorders();
                }
            } catch (e) {
                console.error('initProjectCardBorders failed:', e);
            }
        })();
        
        setupAccordion();
        setupMarquee();
    }

    document.addEventListener('astro:page-load', initPage);
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initPage);
    } else {
        initPage();
    }
</script>

<style>
    :root {
        --project-image-width: 800px;
        --project-text-width: 800px;
    }

    .hero-section {
        padding-top: 20px;   /* 💡 画面上部との間の余白を追加（好みに応じて数値を調整） */
        min-height: 150px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: stretch;
        width: 100%;
    }

    .canvas-wrapper {
        position: relative;
        min-height: 80px;
        width: 100%;
    }

    .canvas-wrapper canvas {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
    }

    .procedural-divider {
        display: block;
        width: 100vw !important;
        max-width: none !important;
        height: 20px;
        position: relative;
        left: 50%;
        transform: translateX(-50%);
        margin-top: 0px;
    }

    canvas {
        opacity: 0;
        animation: fadeIn 0.8s ease-out forwards;
        animation-delay: 0.1s; 
    }

    @keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }

    .main-container {
        width: 86vw;
        margin: 0 auto;
        padding: 0px 0 40px 0;
    }

    .accordion-item {
        border-bottom: 2px solid black;
        width: 100%;
    }

    .accordion-item:first-child {
        border-top: 2px solid black;
    }

    .accordion-header {
        width: 100%;
        background: none;
        border: none;
        font-family: inherit;
        font-size: 32px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 30px 0;
        cursor: pointer;
        text-align: left;
        color: #333;
        transition: color 0.2s ease;
    }

    .accordion-header:hover {
        color: #888;
    }

    .accordion-content {
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.3s ease-out;
    }

    .inner-content {
        padding: 10px 0 40px 0;
        font-size: 22px;
        line-height: 1.6;
    }

    .title-wrapper { 
        display: flex; 
        align-items: center; 
    }

    .arrow { 
        display: inline-block; 
        margin-right: 12px; 
        font-family: monospace; 
        font-size: 0.9em; 
        transition: transform 0.3s ease; 
    }

    .accordion-item.active .arrow { 
        transform: rotate(90deg); 
    }

    /* -------------------------------------
       Featured Projects
       ------------------------------------- */
    .featured-section {
        width: 100vw;
        position: relative;
        left: 50%;
        transform: translateX(-50%);
        overflow: hidden;
        margin-top: 0px;
        margin-bottom: 20px;
    }

    .marquee-container {
        width: 100%;
        overflow: hidden;
        user-select: none;
    }

    .marquee-track {
        display: flex;
        width: max-content;
        opacity: 0;
        transition: opacity 0.5s ease;
    }

    .marquee-track.is-loaded {
        opacity: 1;
    }

    .project-block {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 16px;
        padding: 20px;
        background-color: transparent;
        border-radius: 6px;
        transition: background-color 0.2s ease;
        text-decoration: none;
        color: inherit;
        flex-shrink: 0;
        margin-right: 40px;
        width: var(--project-image-width);
    }

    .project-block:hover {
        background-color: #eeeeee;
    }

    .image-wrapper {
        width: var(--project-image-width);
        aspect-ratio: 16 / 9;
        border: 2px solid transparent; 
        box-sizing: border-box;
        overflow: hidden;
        background-color: #f0f0f0;
    }

    .project-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .project-text-content {
        display: flex;
        flex-direction: column;
        justify-content: flex-start;
        gap: 10px;
        width: 100%;
        white-space: normal;
    }

    .project-block-title {
        font-size: 32px; 
        font-weight: bold;
        margin: 0;
        line-height: 1.1;
    }

    .project-block-desc {
        font-size: 18px; 
        color: #555;
        margin: 0;
        line-height: 1.5;
    }

    /* -------------------------------------
       More Projects Link
       ------------------------------------- */
    .more-projects-link {
        width: 86vw;
        margin: 30px auto 0 auto;
        text-align: left;
        font-size: 20px;
    }

    .more-projects-link a {
        color: #000;
        text-decoration: underline;
        text-underline-offset: 4px;
        transition: color 0.2s ease;
    }

    .more-projects-link a:hover {
        color: #888;
    }

</style>