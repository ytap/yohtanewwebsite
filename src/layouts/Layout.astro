---
// src/layouts/Layout.astro
interface Props {
    title?: string;
    isHome?: boolean;
    isWip?: boolean;
}

const { title = "Portfolio: Yohta Kitagawa", isHome = false, isWip = false } = Astro.props;
---
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <title>{title}</title>
    <style is:global>
        @font-face {
            font-family: 'CothamSans';
            src: url('/yohtanewwebsite/fonts/CothamSans.otf') format('opentype');
            font-weight: normal;
            font-style: normal;
            font-display: swap;
        }

        body {
            font-family: CothamSans, sans-serif;
            margin: 0;
            padding: 0;
            background-color: var(--body-bg, #f5f5f5);
            color: var(--body-color, #333);
            overflow-x: hidden;
        }

        .main-container {
            width: 86vw;
            margin: 0 auto;
            padding: 0px 0 40px 0;
        }

        .hero-section {
            padding-top: 40px;
            min-height: 150px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: flex-start;
            gap: 0px;
            width: 100%;
        }

        /* 💡 下層ページ専用のヘッダー定義を追加（メインページと縦座標を完全に一致させる） */
        .sub-hero-section {
            padding-top: 65px;       /* メインページの中央寄せ計算（40px + 25px）に厳密に揃えた数値 */
            padding-bottom: 15px;    /* 波線下のコンテンツとの距離を最適化 */
            display: flex;
            flex-direction: column;
            justify-content: flex-start;
            align-items: flex-start;
            gap: 0px;
            width: 100%;
        }

        .sub-header-title {
            font-size: 32px;
            font-weight: normal;
            margin: 0 0 10px 0;
            line-height: 1.2;
            opacity: 0;
            animation: fadeIn 0.8s ease-out forwards;
            animation-delay: 0.1s;
        }
        .sub-header-title a {
            color: #4ac3e1;
            text-decoration: none;
            transition: opacity 0.2s ease;
        }
        .sub-header-title a:hover {
            opacity: 0.7;
        }

        .procedural-divider {
            width: 100vw !important;
            max-width: none !important;
            height: 20px;
            position: relative;
            left: 50%;
            transform: translateX(-50%);
            margin-top: 0px;
        }

        canvas {
            opacity: 0;
            animation: fadeIn 0.8s ease-out forwards;
            animation-delay: 0.1s;
        }

        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        .menu-btn {
            position: fixed;
            top: 2rem;
            right: 2rem;
            z-index: 100;
            width: 30px;
            height: 24px;
            cursor: pointer;
            background: transparent;
            border: none;
            padding: 0;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }
        .menu-btn span { display: block; width: 100%; height: 2px; background-color: #333; transition: all 0.3s ease; }
        .menu-btn.open span:nth-child(1) { transform: translateY(11px) rotate(45deg); }
        .menu-btn.open span:nth-child(2) { opacity: 0; }
        .menu-btn.open span:nth-child(3) { transform: translateY(-11px) rotate(-45deg); }

        .menu-overlay {
            position: fixed;
            top: 0; left: 0; width: 100vw; height: 100vh;
            background-color: rgba(255, 255, 255, 0.95);
            z-index: 90;
            display: flex; flex-direction: column; align-items: flex-end;
            padding-right: 2vw; padding-top: 3rem; box-sizing: border-box;
            opacity: 0; pointer-events: none; transition: opacity 0.4s ease;
        }
        .menu-overlay.open { opacity: 1; pointer-events: auto; }
        .menu-overlay ul { list-style: none; padding: 0; margin: 0; text-align: right; width: auto; }
        .menu-overlay li { margin: 1rem 0; }
        .menu-overlay a { text-decoration: none; color: #333; font-size: 1.8rem; font-weight: bold; transition: color 0.2s; }
        .menu-overlay a:hover { color: #888; }

        /* 💡 共通フッターのグローバルスタイル定義 */
        .site-footer {
            margin-top: 120px;
            padding-bottom: 40px;
            width: 100%;
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            box-sizing: border-box;
        }

        .footer-email {
            font-size: 18px;
            color: #333;
            margin: 0;
            text-align: left;
        }

        .footer-instagram {
            font-size: 18px;
            margin: 0;
            text-align: right;
        }

        .footer-instagram a {
            color: #333;
            text-decoration: underline;
            text-underline-offset: 4px;
            transition: color 0.2s ease;
        }

        .footer-instagram a:hover {
            color: #888;
        }
    </style>
    {isWip && (
        <style>
            :root {
                --body-bg: #000000;
                --body-color: #ffffff;
            }
        </style>
    )}
</head>
<body data-is-home={String(isHome)} data-is-wip={String(isWip)}>
    <button id="menu-btn" class="menu-btn" aria-label="Menu">
        <span></span><span></span><span></span>
    </button>

        <nav id="mobile-menu" class="menu-overlay">
        <ul>
            <li><a href="/yohtanewwebsite/">Main page</a></li>
            <li><a href="/yohtanewwebsite/about">About</a></li>
            <li><a href="/yohtanewwebsite/archive">Archive</a></li>
            <li><a href="/yohtanewwebsite/wip">WIP Garden</a></li>
        </ul>
    </nav>

    {!isHome && (
        <div class="main-container">
            <header class="sub-hero-section">
                <h1 class="sub-header-title">
                    <a href="/yohtanewwebsite/">Yohta Kitagawa</a>
                </h1>
                <canvas id="divider-canvas" class="procedural-divider"></canvas>
            </header>
        </div>
    )}

    <main>
        <slot />
    </main>

    <div class="main-container" style="padding-top: 0; padding-bottom: 0;">
        <footer class="site-footer">
            <p class="footer-email">Contact: ykitagawa[at]keio.jp</p>
            <p class="footer-instagram">
                <a href="https://instagram.com/yohta_kitagawa" target="_blank" rel="noopener noreferrer">Instagram</a>
            </p>
        </footer>
    </div>

    <script type="module">
        function setupMenu() {
            const btn = document.getElementById('menu-btn');
            const menu = document.getElementById('mobile-menu');
            const links = menu?.querySelectorAll('a');
            if (!btn || !menu) return;
            btn.addEventListener('click', () => {
                btn.classList.toggle('open');
                menu.classList.toggle('open');
            });
            links?.forEach(link => {
                link.addEventListener('click', () => {
                    btn.classList.remove('open');
                    menu.classList.remove('open');
                });
            });
        }
        document.addEventListener('astro:page-load', setupMenu);
        setupMenu();
    </script>

    <script type="module">
    function setupLayoutScripts() {
        const isWip = document.body.dataset.isWip === 'true';
        const isHome = document.body.dataset.isHome === 'true';

        if (!isWip && !isHome) {
            import('../scripts/noiseBackground.js').then(mod => {
                if (mod && typeof mod.initNoiseBackground === 'function') {
                    mod.initNoiseBackground(2);
                }
            }).catch(e => console.error('Failed to load noiseBackground:', e));
        }

        if (!isHome) {
            const dividerCanvas = document.getElementById('divider-canvas');
            if (dividerCanvas && dividerCanvas instanceof HTMLCanvasElement && dividerCanvas.dataset.initialized !== 'true') {
                dividerCanvas.dataset.initialized = 'true';
                const dividerCtx = dividerCanvas.getContext('2d');
                if (!dividerCtx) return;
                // create a local non-null binding so downstream closures see a definite CanvasRenderingContext2D
                const ctx = /** @type {CanvasRenderingContext2D} */ (dividerCtx);

                const dpr = window.devicePixelRatio || 1;
                const dividerCssHeight = 20;
                let dividerWidth = window.innerWidth;

                dividerCanvas.width = dividerWidth * dpr;
                dividerCanvas.height = dividerCssHeight * dpr;
                dividerCanvas.style.height = dividerCssHeight + 'px';
                ctx.scale(dpr, dpr);

                    let lines = /** @type {Array<{x:number,length:number}>} */ ([]);
                let currentSpeed = 90;
                const targetSpeed = 1.9;
                let brakeForce = 0.05;

                function renderDivider() {
                    if (!document.getElementById('divider-canvas') || document.body.dataset.isHome === 'true') {
                        return;
                    }

                    if (brakeForce < 0.08) {
                        brakeForce += 0.0005;
                    }
                    currentSpeed += (targetSpeed - currentSpeed) * brakeForce;

                    ctx.clearRect(0, 0, dividerWidth, dividerCssHeight);
                    ctx.strokeStyle = 'rgb(51,51,51)';
                    ctx.lineWidth = 1.5;
                    
                    for (let i = 0; i < lines.length; i++) {
                        lines[i].x -= currentSpeed;
                        ctx.beginPath();
                        ctx.moveTo(lines[i].x, dividerCssHeight / 2);
                        ctx.lineTo(lines[i].x + lines[i].length, dividerCssHeight / 2);
                        ctx.stroke();
                    }
                    
                    lines = lines.filter(line => line.x + line.length > 0);
                    
                    if (lines.length > 0) {
                        let rightmostLine = lines[lines.length - 1];
                        let rightmostX = rightmostLine.x + rightmostLine.length;
                        while (rightmostX < dividerWidth) {
                            const space = 12 + Math.random() * 36;
                            const length = 8 + Math.random() * 24;
                            const newX = rightmostX + space;
                            lines.push({ x: newX, length: length });
                            rightmostX = newX + length;
                        }
                    } else {
                        const length = 8 + Math.random() * 24;
                        lines.push({ x: dividerWidth, length: length });
                    }
                    
                    requestAnimationFrame(renderDivider);
                }
                renderDivider();

                window.addEventListener('resize', () => {
                    if (document.body.dataset.isHome === 'true') return;
                    dividerWidth = window.innerWidth;
                    dividerCanvas.width = dividerWidth * dpr;
                    dividerCanvas.height = dividerCssHeight * dpr;
                    ctx.scale(dpr, dpr);
                });
            }
        }
    }

    document.addEventListener('astro:page-load', setupLayoutScripts);
    setupLayoutScripts();
</script>
</body>
</html>