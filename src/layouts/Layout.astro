---
// src/layouts/Layout.astro
---
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <title>Portfolio: Yohta Kitagawa</title>
    <style is:global>
        @font-face {
            font-family: 'CothamSans';
            src: url('/fonts/CothamSans.otf') format('opentype');
            font-weight: normal;
            font-style: normal;
            font-display: swap;
        }

        body {
            font-family: CothamSans, sans-serif;
            margin: 0;
            padding: 0;
            background-color: #f5f5f5;
            color: #333;
            overflow-x: hidden;
        }

        .menu-btn {
            position: fixed;
            top: 2rem;
            right: 2rem;
            z-index: 100;
            width: 30px;
            height: 24px;
            cursor: pointer;
            background: transparent;
            border: none;
            padding: 0;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .menu-btn span {
            display: block;
            width: 100%;
            height: 2px;
            background-color: #333;
            transition: all 0.3s ease;
        }

        .menu-btn.open span:nth-child(1) {
            transform: translateY(11px) rotate(45deg);
        }
        .menu-btn.open span:nth-child(2) {
            opacity: 0;
        }
        .menu-btn.open span:nth-child(3) {
            transform: translateY(-11px) rotate(-45deg);
        }

        .menu-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            background-color: rgba(255, 255, 255, 0.95);
            z-index: 90;
            
            display: flex;
            flex-direction: column;
            align-items: flex-end; /* 右寄せに戻しました */
            
            padding-right: 2vw; /* ここで画面右端からの距離を調整できます */
            padding-top: 3rem;
            box-sizing: border-box;

            opacity: 0;
            pointer-events: none;
            transition: opacity 0.4s ease;
        }

        .menu-overlay.open {
            opacity: 1;
            pointer-events: auto;
        }

        .menu-overlay ul {
            list-style: none;
            padding: 0;
            margin: 0;
            text-align: right; /* テキストを右揃えに戻しました */
            width: auto;
        }

        .menu-overlay li {
            margin: 1rem 0;
        }

        .menu-overlay a {
            text-decoration: none;
            color: #333;
            font-size: 1.8rem; 
            font-weight: bold;
            transition: color 0.2s;
        }

        .menu-overlay a:hover {
            color: #888;
        }

        main {
            padding-top: 1rem;
        }

        /* Shared header / canvas rules (moved from page-level styles) */
        .hero-section {
            padding: 10px 0 30px 0;
            display: flex;
            flex-direction: column;
            justify-content: flex-start;
            align-items: flex-start;
            gap: 0px;
        }
        .canvas-wrapper {
            position: relative;
            width: 100%;
            height: 170px;
        }
        .procedural-title, .procedural-about {
            position: absolute;
            top: 0;
            left: 0;
            max-width: 100%;
            height: auto;
        }
        .procedural-divider {
            width: 100vw;
            height: 0px;
            position: relative;
            left: 50%;
            transform: translateX(-50%);
            margin-top: 0px;
            margin-bottom: 0px;
        }
    </style>
</head>
<body>
    <button id="menu-btn" class="menu-btn" aria-label="Menu">
        <span></span>
        <span></span>
        <span></span>
    </button>

    <nav id="mobile-menu" class="menu-overlay">
        <ul>
            <li><a href="/">Main page</a></li>
            <li><a href="/wip">WIP Garden</a></li>
        </ul>
    </nav>

    <main>
        <slot />
    </main>

    <script type="module">
        function setupMenu() {
            const btn = document.getElementById('menu-btn');
            const menu = document.getElementById('mobile-menu');
            const links = menu?.querySelectorAll('a');

            if (!btn || !menu) return;

            btn.addEventListener('click', () => {
                btn.classList.toggle('open');
                menu.classList.toggle('open');
            });

            links?.forEach(link => {
                link.addEventListener('click', () => {
                    btn.classList.remove('open');
                    menu.classList.remove('open');
                });
            });
        }

        document.addEventListener('astro:page-load', setupMenu);
        setupMenu();

        

        if (!sessionStorage.getItem('siteEntryPoint')) {
            sessionStorage.setItem('siteEntryPoint', Date.now().toString());
        }
    </script>
</body>
</html>